# Kconfig - LuDLC module options

menu "LuDLC"

config LUDLC
	bool "LuDLC stack"
	default n
	help
	  Enable the LuDLC .

if LUDLC

config LUDLC_MT
	bool
	default y

config LUDLC_SERIAL_CONN
	bool "LuDLC Serial connection support"
	default n
	depends on SERIAL
	select CRC # Serial transport requires CRC
	select EVENTS
	help
	  Build LuDLC with serial (UART) connection support.

config LUDLC_STATIC_SERIAL_CONN
	bool "Predefine LuDLC Serial connection as static array"
	default n
	depends on LUDLC_SERIAL_CONN

config LUDLC_STATIC_SERIAL_CONN_NUM
	int "Number of predefine connections"
	default 1
	depends on LUDLC_STATIC_SERIAL_CONN

endif # LUDLC

endmenu
