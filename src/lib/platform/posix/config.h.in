/* define #undef for 0 values, like Linux autoconf.h */

/**
 * @def LUDLC_STATIC_LIBRARY
 * @brief Defined (as 1) if LuDLC is being built as a static library.
 */
#cmakedefine01	LUDLC_STATIC_LIBRARY
#if !LUDLC_STATIC_LIBRARY
# undef LUDLC_STATIC_LIBRARY
#endif

/**
 * @def LUDLC_SHARED_LIBRARY
 * @brief Defined (as 1) if LuDLC is being built as a shared library (DLL).
 */
#cmakedefine01	LUDLC_SHARED_LIBRARY
#if !LUDLC_SHARED_LIBRARY
# undef LUDLC_SHARED_LIBRARY
#endif

/**
 * @def CONFIG_LUDLC_SERIAL_CONN
 * @brief Defined (as 1) to include the serial (UART) connection transport.
 */
#cmakedefine01	CONFIG_LUDLC_SERIAL_CONN
#if !CONFIG_LUDLC_SERIAL_CONN
# undef CONFIG_LUDLC_SERIAL_CONN
#endif

/**
 * @def CONFIG_LUDLC_MT
 * @brief Defined (as 1) to enable multi-threading support (e.g., for
 * deferred callbacks).
 */
#cmakedefine01	CONFIG_LUDLC_MT
#if !CONFIG_LUDLC_MT
# undef CONFIG_LUDLC_MT
#endif

/**
 * @def LUDLC_STATIC_CONN
 * @brief Defined (as 1) to use a static pool for serial connections (POSIX).
 */
#cmakedefine01	LUDLC_STATIC_CONN
#if !LUDLC_STATIC_CONN
# undef LUDLC_STATIC_CONN
#endif

/** @brief Number of slots in the static serial connection pool (POSIX). */
#define LUDLC_STATIC_CONN_NUM	@LUDLC_STATIC_CONN_NUM@

