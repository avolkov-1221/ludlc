source "Kconfig.zephyr"

menu "LuDLC echo sample options"

config LUDLC_ECHO_PERIODIC_TX
	bool "Enable periodic ECHO packet transmission"
	default y
	help
	  When enabled, the sample sends one ECHO packet per second in addition
	  to counterpart-style ECHO replies.

endmenu
